QM_BASE_URL=https://bbvamx.quantummetric.com
QM_BROWSER=chrome
QM_SESSION_MODE=browser
QM_COUNTRY=MX
QM_VERIFY_TLS=true
# Optional override. By default packaged app data lives in the user data directory.
# macOS: ~/Library/Application Support/SDS Quantum Metric
# Linux: ~/.local/share/SDS Quantum Metric
# Windows: %LOCALAPPDATA%/SDS Quantum Metric
# QM_DATA_DIR=data
QM_DASHBOARD_ID=
QM_TEAM_ID=
QM_DASHBOARD_TAB=0
QM_COUNTRY_CONFIGS=
QUANTUM_DEFAULT_BASE_URL=https://bbvamx.quantummetric.com
QUANTUM_DEFAULT_DASHBOARD_ID=
QUANTUM_DEFAULT_TEAM_ID=
QUANTUM_DEFAULT_SUMMARY_TAB=0
QUANTUM_DEFAULT_ERRORS_TAB=1
QUANTUM_CAPTURE_TIMEOUT_SECONDS=120
QUANTUM_REGRESSION_TOLERANCE_PERCENT=0.1
# Profundidad por defecto usada por el boton Ingestar de la pantalla Ingesta.
QUANTUM_INGESTION_DEPTH_DAYS=30
QUANTUM_INCREMENTAL_REPROCESS_DAYS=1
QUANTUM_INGESTION_CHUNK_DAYS=1
QUANTUM_THEME_PREFERENCE=system
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
